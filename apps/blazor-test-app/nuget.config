<?xml version="1.0" encoding="utf-8"?>
<!-- In CI pipelines, NuGetAuthenticate provides credentials for the internal
     CFS-backed feed so dotnet restore pulls packages without hitting api.nuget.org
     directly (required by CFSClean network isolation policy).
     External contributors without internal feed access will transparently fall
     back to the nuget.org source listed below. -->
<configuration>
  <packageSources>
    <clear />
    <add key="CFS-NuGet" value="https://office.pkgs.visualstudio.com/ISS/_packaging/ISS_PublicPackages/nuget/v3/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
